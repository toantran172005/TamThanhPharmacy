<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.quanlyhieuthuoc.QuanLyThueController">
   <children>
      <VBox layoutX="14.0" layoutY="14.0" spacing="15.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
         <children>
            <Label text="Quản lý Thuế">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
            </Label>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleThemMoi" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Thêm mới">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleCapNhat" style="-fx-background-color: #2980b9;" text="Cập nhật tình trạng" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleXoa" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="Xóa">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            <HBox alignment="BOTTOM_LEFT" spacing="15.0" style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-border-color: #bdc3c7; -fx-border-width: 1;">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Lọc theo loại thuế:" />
                        <ComboBox fx:id="loaiThueFilterComboBox" prefWidth="180.0" promptText="Tất cả loại thuế" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Lọc theo tình trạng:" />
                        <ComboBox fx:id="tinhTrangFilterComboBox" prefWidth="180.0" promptText="Tất cả tình trạng" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Từ ngày:" />
                        <DatePicker fx:id="tuNgayDatePicker" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Đến ngày:" />
                        <DatePicker fx:id="denNgayDatePicker" />
                     </children>
                  </VBox>
                  <Button mnemonicParsing="false" onAction="#handleTimKiem" text="Tìm kiếm" />
               </children>
            </HBox>
            <TableView fx:id="taxTableView" prefHeight="400.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="maSoColumn" prefWidth="75.0" text="Mã số" />
                <TableColumn fx:id="loaiThueColumn" prefWidth="150.0" text="Loại thuế" />
                  <TableColumn fx:id="kyKeKhaiColumn" prefWidth="120.0" text="Kỳ kê khai" />
                  <TableColumn fx:id="doanhThuChiuThueColumn" prefWidth="150.0" text="Doanh thu chịu thuế" />
                  <TableColumn fx:id="soThuePhaiNopColumn" prefWidth="150.0" text="Số thuế phải nộp" />
                  <TableColumn fx:id="ngayNopColumn" prefWidth="120.0" text="Ngày nộp" />
                  <TableColumn fx:id="tinhTrangColumn" prefWidth="120.0" text="Tình trạng" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Label text="Tổng số thuế phải nộp:">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>
                  <Label fx:id="tongThueLabel" text="0 VND" textFill="#c0392b">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>
               </children>
               <padding>
                  <Insets top="5.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>