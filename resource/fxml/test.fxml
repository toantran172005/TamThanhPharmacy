<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ThongKeHoaDonController">

   <!-- ======== TOP FILTER ======== -->
   <top>
      <VBox spacing="8">
         <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
         </padding>
         <children>
            <Label text="📊 THỐNG KÊ HÓA ĐƠN - DOANH THU TIỆM THUỐC" 
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
               <children>
                  <Label text="Từ ngày:"/>
                  <DatePicker fx:id="dpTuNgay"/>
                  <Label text="Đến ngày:"/>
                  <DatePicker fx:id="dpDenNgay"/>
                  <Label text="Khách hàng:"/>
                  <TextField fx:id="txtKhachHang" promptText="Nhập tên hoặc số điện thoại..."/>
                  <Button fx:id="btnThongKe" text="Thống Kê" 
                          style="-fx-background-color: #2a73cc; -fx-text-fill: white;"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>

   <!-- ======== CENTER CONTENT ======== -->
   <center>
      <VBox spacing="15">
         <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
         </padding>
         <children>

            <!-- Tổng quan doanh thu -->
            <TitledPane text="Tổng Quan Doanh Thu" expanded="true">
               <content>
                  <HBox spacing="25" alignment="CENTER">
                     <children>
                        <VBox alignment="CENTER">
                           <children>
                              <Label text="Tổng Doanh Thu"/>
                              <Label fx:id="lblTongDoanhThu" text="0 VND" 
                                     style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: green;"/>
                           </children>
                        </VBox>
                        <VBox alignment="CENTER">
                           <children>
                              <Label text="Tổng Số Hóa Đơn"/>
                              <Label fx:id="lblTongHoaDon" text="0"/>
                           </children>
                        </VBox>
                        <VBox alignment="CENTER">
                           <children>
                              <Label text="Số Khách Hàng Độc Đáo"/>
                              <Label fx:id="lblSoKhachHang" text="0"/>
                           </children>
                        </VBox>
                        <VBox alignment="CENTER">
                           <children>
                              <Label text="Doanh Thu TB/Hóa Đơn"/>
                              <Label fx:id="lblDoanhThuTB" text="0 VND"/>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </content>
            </TitledPane>

            <!-- Biểu đồ doanh thu -->
            <TitledPane text="Biểu Đồ Doanh Thu Theo Ngày">
               <content>
                  <LineChart fx:id="chartDoanhThu" title="Doanh Thu Theo Ngày" prefHeight="200">
                     <xAxis>
                        <CategoryAxis label="Ngày"/>
                     </xAxis>
                     <yAxis>
                        <NumberAxis label="Doanh thu (VND)"/>
                     </yAxis>
                  </LineChart>
               </content>
            </TitledPane>

            <!-- Top khách hàng -->
            <TitledPane text="Top 10 Khách Hàng Mua Nhiều Nhất" expanded="true">
               <content>
                  <TableView fx:id="tblTopKhach" prefHeight="250">
                     <columns>
                        <TableColumn text="STT" prefWidth="50"/>
                        <TableColumn text="Tên Khách Hàng" prefWidth="180"/>
                        <TableColumn text="Số Điện Thoại" prefWidth="120"/>
                        <TableColumn text="Số Hóa Đơn" prefWidth="100"/>
                        <TableColumn text="Tổng Mua" prefWidth="120"/>
                        <TableColumn text="Ghi Chú" prefWidth="150"/>
                     </columns>
                  </TableView>
               </content>
            </TitledPane>

            <!-- Chi tiết hóa đơn -->
            <TitledPane text="Chi Tiết Hóa Đơn Của Khách Được Chọn">
               <content>
                  <TableView fx:id="tblChiTiet" prefHeight="200">
                     <columns>
                        <TableColumn text="Mã Hóa Đơn" prefWidth="120"/>
                        <TableColumn text="Ngày Lập" prefWidth="120"/>
                        <TableColumn text="Tổng Tiền" prefWidth="120"/>
                        <TableColumn text="Trạng Thái" prefWidth="120"/>
                     </columns>
                  </TableView>
               </content>
            </TitledPane>

         </children>
      </VBox>
   </center>

   <!-- ======== BOTTOM BUTTONS ======== -->
   <bottom>
      <HBox spacing="10" alignment="CENTER_RIGHT">
         <padding>
            <Insets top="8" right="12" bottom="8" left="12"/>
         </padding>
         <children>
            <Button fx:id="btnXuatExcel" text="Xuất Excel Top Khách"/>
            <Button fx:id="btnInBaoCao" text="In Báo Cáo Doanh Thu"/>
            <Button fx:id="btnLamMoi" text="Làm Mới Dữ Liệu"/>
            <Button fx:id="btnDong" text="Đóng"/>
         </children>
      </HBox>
   </bottom>
</BorderPane>
